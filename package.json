    "dotenv": "^16.4.5",
    "groq-sdk": "^1.3.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
